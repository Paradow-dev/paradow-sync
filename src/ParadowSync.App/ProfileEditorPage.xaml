<Page
    x:Class="ParadowSync.App.ProfileEditorPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="16">
        <StackPanel MaxWidth="720">
            <TextBlock
                x:Name="TitleText"
                Margin="0,0,0,12"
                FontSize="20"
                FontWeight="SemiBold"
                Text="Éditeur de profil" />

            <TextBlock Text="Nom du profil" />
            <TextBox
                x:Name="NameBox"
                Margin="0,4,0,12" />

            <TextBlock Margin="0,0,0,8" FontWeight="SemiBold" Text="Comptes" />
            <ListView x:Name="AccountsList" MinHeight="180" Margin="0,0,0,12" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="60" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Account ID" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Personnage" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Classe" />
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="Écran" />

                            <TextBox Grid.Row="1" Grid.Column="0" Margin="0,0,4,4" Text="{Binding AccountId, Mode=TwoWay}" />
                            <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,4,4" Text="{Binding Character, Mode=TwoWay}" />
                            <ComboBox
                                Grid.Row="1"
                                Grid.Column="2"
                                Margin="0,0,4,4"
                                ItemsSource="{Binding DataContext.ClassNames, ElementName=RootPage}"
                                SelectedItem="{Binding Class, Mode=TwoWay}" />
                            <TextBox Grid.Row="1" Grid.Column="3" Margin="0,0,0,4" Text="{Binding MonitorText, Mode=TwoWay}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,4,0" Text="X" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,0,4,0" Text="Y" />
                            <TextBlock Grid.Row="2" Grid.Column="2" Margin="0,0,4,0" Text="Largeur" />
                            <TextBlock Grid.Row="2" Grid.Column="3" Text="Hauteur" />

                            <TextBox Grid.Row="3" Grid.Column="0" Margin="0,0,4,0" Text="{Binding XText, Mode=TwoWay}" />
                            <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,4,0" Text="{Binding YText, Mode=TwoWay}" />
                            <TextBox Grid.Row="3" Grid.Column="2" Margin="0,0,4,0" Text="{Binding WText, Mode=TwoWay}" />
                            <TextBox Grid.Row="3" Grid.Column="3" Text="{Binding HText, Mode=TwoWay}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                <Button Margin="0,0,8,0" Content="Ajouter un compte" Click="OnAddAccountClick" />
                <Button Content="Retirer le dernier" Click="OnRemoveAccountClick" />
            </StackPanel>

            <TextBlock Margin="0,0,0,8" FontWeight="SemiBold" Text="Overlay" />
            <CheckBox x:Name="TeamStripEnabledBox" Margin="0,0,0,8" Content="Bandeau d'équipe activé" />
            <TextBlock Text="Position du bandeau" />
            <ComboBox
                x:Name="TeamStripPositionBox"
                Margin="0,4,0,8"
                Width="200"
                HorizontalAlignment="Left" />
            <TextBlock Text="Écran du bandeau" />
            <TextBox
                x:Name="TeamStripMonitorBox"
                Margin="0,4,0,8"
                Width="200"
                HorizontalAlignment="Left" />
            <CheckBox x:Name="BadgesEnabledBox" Margin="0,0,0,12" Content="Badges sur fenêtres activés" />

            <TextBlock Margin="0,0,0,8" FontWeight="SemiBold" Text="Raccourcis (info MVP)" />
            <TextBlock Text="Focus slots" />
            <TextBox x:Name="HotkeyFocusBox" Margin="0,4,0,8" />
            <TextBlock Text="Basculer overlay" />
            <TextBox x:Name="HotkeyToggleOverlayBox" Margin="0,4,0,8" />
            <TextBlock Text="Arrêter tout" />
            <TextBox x:Name="HotkeyStopAllBox" Margin="0,4,0,12" />

            <StackPanel Orientation="Horizontal">
                <Button Margin="0,0,8,0" Content="Enregistrer" Click="OnSaveClick" />
                <Button Content="Annuler" Click="OnCancelClick" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
