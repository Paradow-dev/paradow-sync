<Window
    x:Class="ParadowSync.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="paradow-sync"
    Width="900"
    Height="600">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            FontSize="20"
            FontWeight="SemiBold"
            Text="Profils d'équipe" />

        <Grid Grid.Row="1" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ListView
                x:Name="ProfileListView"
                Grid.Column="0"
                SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4">
                            <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                            <TextBlock
                                Foreground="Gray"
                                Text="{Binding AccountLabel}" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel
                Grid.Column="1"
                Margin="12,0,0,0"
                VerticalAlignment="Top">
                <Button x:Name="NewButton" Margin="0,0,0,8" Content="Nouveau" Click="OnNewClick" />
                <Button x:Name="EditButton" Margin="0,0,0,8" Content="Modifier" Click="OnEditClick" />
                <Button x:Name="DeleteButton" Margin="0,0,0,8" Content="Supprimer" Click="OnDeleteClick" />
                <Button x:Name="LaunchButton" Margin="0,0,0,8" Content="Lancer" Click="OnLaunchClick" />
                <Button x:Name="StopButton" Content="Arrêter" Click="OnStopClick" />
            </StackPanel>
        </Grid>

        <TextBlock
            x:Name="StatusTextBlock"
            Grid.Row="2"
            Foreground="Gray"
            Text="Prêt" />
    </Grid>
</Window>
